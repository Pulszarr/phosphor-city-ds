{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "Phosphor City",
  "description": "Dark Japanese cyberpunk design system",

  "color": {
    "bg": {
      "void":     { "$value": "#030A05", "$type": "color" },
      "base":     { "$value": "#0A1A0D", "$type": "color" },
      "surface":  { "$value": "#112215", "$type": "color" },
      "elevated": { "$value": "#1A3320", "$type": "color" }
    },
    "green": {
      "neon":   { "$value": "#00FF5C", "$type": "color" },
      "bright": { "$value": "#00CC4A", "$type": "color" },
      "mid":    { "$value": "#009933", "$type": "color" },
      "deep":   { "$value": "#1A4A25", "$type": "color" },
      "muted":  { "$value": "#0D2B18", "$type": "color" }
    },
    "amber": {
      "glow": { "$value": "#F0D060", "$type": "color" },
      "mid":  { "$value": "#C48A20", "$type": "color" },
      "dim":  { "$value": "#7A5510", "$type": "color" }
    },
    "structure": {
      "dark": { "$value": "#151F12", "$type": "color" },
      "wire": { "$value": "#0D150A", "$type": "color" }
    },
    "text": {
      "body":    { "$value": "#A8D4B0", "$type": "color" },
      "caption": { "$value": "#4A7A55", "$type": "color" },
      "inverse": { "$value": "#030A05", "$type": "color" }
    }
  },

  "font": {
    "family": {
      "display": { "$value": "JetBrains Mono, monospace", "$type": "fontFamily" },
      "body":    { "$value": "Inter, sans-serif",         "$type": "fontFamily" }
    },
    "weight": {
      "light":   { "$value": 300, "$type": "fontWeight" },
      "body":    { "$value": 500, "$type": "fontWeight" },
      "display": { "$value": 700, "$type": "fontWeight" }
    }
  },

  "spacing": {
    "1":  { "$value": "4px",  "$type": "spacing" },
    "2":  { "$value": "8px",  "$type": "spacing" },
    "3":  { "$value": "12px", "$type": "spacing" },
    "4":  { "$value": "16px", "$type": "spacing" },
    "6":  { "$value": "24px", "$type": "spacing" },
    "8":  { "$value": "32px", "$type": "spacing" },
    "12": { "$value": "48px", "$type": "spacing" },
    "16": { "$value": "64px", "$type": "spacing" }
  },

  "borderRadius": {
    "sm":   { "$value": "4px",    "$type": "borderRadius" },
    "md":   { "$value": "8px",    "$type": "borderRadius" },
    "lg":   { "$value": "16px",   "$type": "borderRadius" },
    "full": { "$value": "9999px", "$type": "borderRadius" }
  },

  "shadow": {
    "glow-neon":  { "$value": "0 0 12px #00FF5C55, 0 0 40px #00CC4A22", "$type": "shadow" },
    "glow-amber": { "$value": "0 0 8px #F0D06066, 0 0 24px #C48A2033",  "$type": "shadow" }
  }
}
